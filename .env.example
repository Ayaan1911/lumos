# Copy this file to .env before running docker compose
# Never commit .env to git

# REQUIRED - change before any real deployment
LUMOS_ADMIN_TOKEN=changeme

# Database - local dev only (Docker sets its own internally)
LUMOS_DATABASE_URL=postgresql://lumos:lumos@localhost:5432/lumos
LUMOS_TEST_DATABASE_URL=postgresql://lumos:lumos@localhost:5433/lumos_test

# Token lifetimes in seconds
LUMOS_SESSION_TTL_SECONDS=600
LUMOS_CAPABILITY_TTL_SECONDS=300
LUMOS_NONCE_TTL_SECONDS=60
LUMOS_TIMESTAMP_SKEW_SECONDS=30

# Issuer key path
LUMOS_ISSUER_KEY_PATH=.lumos/issuer_ed25519.key

# Pool sizes
LUMOS_DATABASE_MIN_POOL_SIZE=1
LUMOS_DATABASE_MAX_POOL_SIZE=10
